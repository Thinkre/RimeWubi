{
  "name": "rimewubi",
  "version": "0.1.0",
  "description": "Rime 五笔配置发行版 - macOS 配置 App",
  "main": "main.js",
  "scripts": {
    "start": "node_modules/.bin/electron .",
    "build": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.thinkre.rimewubi",
    "productName": "RimeWubi",
    "mac": {
      "category": "public.app-category.utilities",
      "identity": null,
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ]
    },
    "dmg": {
      "title": "RimeWubi ${version}"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "config/**/*",
      "node_modules/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "Thinkre",
      "repo": "RimeWubi"
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  }
}
